  "publicApiSurface": [
    "useSettings() - Settings context hook for theme and language",
    "useToast() - Toast notifications hook",
    "useTranslations() - Internationalization hook",
    "useDashboardData() - Dashboard data fetching hook",
    "useChartTooltip() - Chart tooltip interactions hook",
    "useDocumentTitle() - Dynamic document title hook",
    "getDashboardSummary() - Fetch dashboard summary data",
    "getMarketData() - Fetch market data from CoinGecko",
    "getPortfolioPerformance() - Fetch portfolio performance",
    "exportToCSV() - Export data to CSV file",
    "formatCurrency() - Format numbers as currency",
    "formatPercentage() - Format numbers as percentages"
